<?xml version="1.0" encoding="utf-8"?>
<!-- Selector cho nút activity: mặc định → đang thu → đã hoàn thành -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State: đã hoàn thành (dùng tag activated) -->
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/teal_50" />
            <stroke android:width="2dp" android:color="@color/teal_600" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- State: đang thu (pressed) -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/error_bg" />
            <stroke android:width="2dp" android:color="@color/error" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="@color/divider" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>