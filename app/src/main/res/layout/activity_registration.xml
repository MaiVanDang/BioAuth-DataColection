<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_secondary"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Header ──────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_registration"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"/>

        <!-- Step indicator dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="20dp"
            android:gravity="center">

            <View
                android:layout_width="20dp"
                android:layout_height="6dp"
                android:background="@drawable/dot_active"
                android:layout_marginEnd="5dp"/>
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/dot_inactive"
                android:layout_marginEnd="5dp"/>
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/dot_inactive"/>
        </LinearLayout>

        <!-- ── Section label ───────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/consent_title"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:textColor="@color/hint_text"
            android:layout_marginBottom="10dp"/>

        <!-- ── Họ và tên ────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hint_name"
                    android:textSize="11sp"
                    android:textColor="@color/hint_text"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:hint="@string/hint_name_ex"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"
                    android:background="@null"
                    android:inputType="textPersonName"
                    android:autofillHints="name"
                    android:importantForAutofill="yes"
                    android:paddingTop="2dp"
                    android:paddingBottom="0dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <!-- Tuổi wrapper -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/hint_age"
                            android:textColor="@color/hint_text"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/etAge"
                            tools:ignore="TouchTargetSizeCheck"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="@null"
                            android:background="@null"
                            android:hint="@string/hint_age_ex"
                            android:importantForAutofill="no"
                            android:inputType="number"
                            android:minHeight="48dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="0dp"
                            android:textColor="@color/on_surface"
                            android:textSize="15sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Placeholder để giữ chiều cao bằng với cột giới tính khi có error -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:visibility="invisible"/>

            </LinearLayout>

            <!-- Giới tính wrapper -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_gender"
                            android:textColor="@color/hint_text"
                            android:textSize="11sp" />

                        <Spinner
                            android:id="@+id/spinnerGender"
                            tools:ignore="TouchTargetSizeCheck"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:minHeight="48dp"
                            android:paddingTop="2dp"
                            android:textSize="15sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Error giới tính -->
                <TextView
                    android:id="@+id/tvGenderError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/error_gender_required"
                    android:textSize="12sp"
                    android:textColor="@color/error"
                    android:drawablePadding="3dp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>

            </LinearLayout>
        </LinearLayout>

        <!-- ── Tay thuận ────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDominantHand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="1dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_dominant_hand"
                    android:textSize="11sp"
                    android:textColor="@color/hint_text"/>

                <Spinner
                    android:id="@+id/spinnerDominantHand"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:background="@null"
                    android:paddingTop="2dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Error tay thuận -->
        <TextView
            android:id="@+id/tvHandError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/error_hand_required"
            android:textSize="12sp"
            android:textColor="@color/error"
            android:drawablePadding="3dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <!-- ── Loại thiết bị ─────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_device"
                    android:textSize="11sp"
                    android:textColor="@color/hint_text"/>

                <EditText
                    android:id="@+id/etDevice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:hint="@string/label_device"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"
                    android:background="@null"
                    android:inputType="textNoSuggestions"
                    android:autofillHints="@null"
                    android:importantForAutofill="no"
                    android:paddingTop="2dp"
                    android:paddingBottom="0dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Consent card ─────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/consent_body"
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginBottom="10dp"/>

                <CheckBox
                    android:id="@+id/cbConsent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/consent_checkbox"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface"
                    android:buttonTint="@color/teal_600"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Error consent -->
        <TextView
            android:id="@+id/tvConsentError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/error_consent_required"
            android:textSize="12sp"
            android:textColor="@color/error"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- ── Nút bắt đầu ───────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/btn_start"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:layout_marginBottom="32dp"
            app:backgroundTint="@color/teal_600"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>
