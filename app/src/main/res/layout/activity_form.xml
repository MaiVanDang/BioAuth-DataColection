<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_secondary"
    android:fitsSystemWindows="true">

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:background="@color/surface_secondary">

        <!-- Hàng 1: Back | UserChip | Logout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <!-- Nút back -->
            <ImageButton
                android:id="@+id/btnBack"
                tools:ignore="TouchTargetSizeCheck,UnlabeledFor"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back_white"
                android:background="@drawable/bg_back_button"
                android:contentDescription="@string/btn_return"
                android:layout_marginEnd="8dp"/>

            <!-- User chip: avatar + tên người dùng -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="4dp"
                    android:paddingEnd="10dp">

                    <!-- Avatar circle -->
                    <TextView
                        android:id="@+id/tvUserAvatar"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_avatar"
                        android:layout_marginEnd="6dp"
                        tools:text="NA"/>

                    <!-- Tên người dùng -->
                    <TextView
                        android:id="@+id/tvUserInfo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="15sp"
                        android:textColor="@color/on_surface"
                        android:singleLine="true"
                        android:ellipsize="end"
                        tools:text="Nguyễn Văn A"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Nút đăng xuất -->
            <ImageButton
                android:id="@+id/btnLogout"
                tools:ignore="TouchTargetSizeCheck,UnlabeledFor"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_logout"
                android:background="@drawable/bg_logout_button"
                android:contentDescription="@string/logout"
                android:padding="8dp"/>

        </LinearLayout>

        <!-- Step dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:gravity="center">
            <View android:layout_width="6dp"  android:layout_height="6dp"
                android:background="@drawable/dot_inactive" android:layout_marginEnd="5dp"/>
            <View android:layout_width="20dp" android:layout_height="6dp"
                android:background="@drawable/dot_active"   android:layout_marginEnd="5dp"/>
            <View android:layout_width="6dp"  android:layout_height="6dp"
                android:background="@drawable/dot_inactive"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Toàn bộ nội dung có thể cuộn ──────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:contentDescription="@string/scroll_content_desc">

        <!-- Container để Kotlin tự động thêm câu hỏi vào -->
        <LinearLayout
            android:id="@+id/formContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/title_form"
            android:textColor="@color/on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ── Nút hoàn tất (cố định ở dưới) ─────────────────────────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="@string/btn_submit"
        android:textSize="15sp"
        android:textColor="@color/white"
        android:layout_margin="16dp"
        android:maxWidth="600dp"
        app:backgroundTint="@color/teal_600"
        app:cornerRadius="12dp"/>

</LinearLayout>