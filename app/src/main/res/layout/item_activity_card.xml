<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Header: Icon + Name/Info + Reset Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvActivityIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="@string/activity_walking_icon"
                android:textSize="25sp"
                android:textColor="@color/on_surface"
                android:contentDescription="@string/activity_walking_icon_desc" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvActivityName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/activity_walking"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="@string/percent"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                tools:ignore="TouchTargetSizeCheck,UnlabeledFor"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="36dp"
                android:layout_height="41dp"
                android:layout_gravity="center_vertical"
                android:contentDescription="@string/reset"
                android:insetLeft="5dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="15dp"
                android:minWidth="36dp"
                android:minHeight="36dp"
                android:padding="6dp"
                app:icon="@drawable/ic_reset"
                app:iconGravity="textStart"
                app:iconSize="30dp"
                app:iconTint="#E53935" />

        </LinearLayout>

        <!-- Progress bar -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/pbActivity"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="4dp"
            android:max="100"
            android:progress="0"
            app:indicatorColor="@color/teal_400"
            app:trackColor="#E0E0E0"
            app:trackCornerRadius="3dp" />

        <!-- Goal Info Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/goal"
                android:textColor="@color/secondary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTimeDone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/timestamp"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Control Area: Minus / Label / Plus -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMinus"
                tools:ignore="TouchTargetSizeCheck,UnlabeledFor"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:contentDescription="@string/minus_ds"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="@string/icon_minus"
                android:textColor="@color/on_surface"
                android:textSize="25sp"
                app:strokeColor="@color/divider" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:textColor="@color/secondary_text"
                android:textSize="10sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlus"
                tools:ignore="TouchTargetSizeCheck,UnlabeledFor"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:contentDescription="@string/plus_ds"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="@string/icon_plus"
                android:textColor="@color/on_surface"
                android:textSize="20sp"
                app:strokeColor="@color/divider" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>