<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_secondary"
    android:fitsSystemWindows="true">

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:background="@color/surface_secondary">

        <!-- Hàng 1: Back | UserChip | Logout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <!-- Nút back -->
            <ImageButton
                android:id="@+id/btnBack"
                tools:ignore="TouchTargetSizeCheck,UnlabeledFor"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back_white"
                android:background="@drawable/bg_back_button"
                android:contentDescription="@string/btn_return"
                android:layout_marginEnd="8dp"/>

            <!-- User chip: avatar + tên người dùng -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="4dp"
                    android:paddingEnd="10dp">

                    <!-- Avatar circle -->
                    <TextView
                        android:id="@+id/tvUserAvatar"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_avatar"
                        android:layout_marginEnd="6dp"
                        tools:text="NA"/>

                    <!-- Tên người dùng -->
                    <TextView
                        android:id="@+id/tvUserInfo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="15sp"
                        android:textColor="@color/on_surface"
                        android:singleLine="true"
                        android:ellipsize="end"
                        tools:text="Nguyễn Văn A"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Nút đăng xuất -->
            <ImageButton
                android:id="@+id/btnLogout"
                tools:ignore="TouchTargetSizeCheck,UnlabeledFor"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_logout"
                android:background="@drawable/bg_logout_button"
                android:contentDescription="@string/logout"
                android:padding="8dp"/>

        </LinearLayout>

        <!-- Step dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:gravity="center">
            <View android:layout_width="6dp"  android:layout_height="6dp"
                android:background="@drawable/dot_inactive" android:layout_marginEnd="5dp"/>
            <View android:layout_width="20dp" android:layout_height="6dp"
                android:background="@drawable/dot_active"   android:layout_marginEnd="5dp"/>
            <View android:layout_width="6dp"  android:layout_height="6dp"
                android:background="@drawable/dot_inactive"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Total progress bar ────────────────────────────────────── -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progress="0"
        app:indicatorColor="@color/teal_400"
        app:trackColor="@color/divider"
        app:trackCornerRadius="0dp"/>

    <!-- ── Scrollable content ────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Total time label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/title_sensor"
                android:textColor="@color/on_surface"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProgressLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/time_ex"
                android:textSize="15sp"
                android:textColor="@color/secondary_text"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <!-- ── Recording indicator ────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecording"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/error"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/error_bg"
                android:visibility="visible"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/viewRecDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/circle_red"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvRecordingStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recording_status_not_run"
                        android:textSize="15sp"
                        android:textColor="@color/coral_800"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_time_ex"
                        android:textSize="15sp"
                        android:textColor="@color/coral_800"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Activity cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <include
                    android:id="@+id/cardWalking"
                    layout="@layout/item_activity_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <include
                    android:id="@+id/cardStanding"
                    layout="@layout/item_activity_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <include
                    android:id="@+id/cardSitting"
                    layout="@layout/item_activity_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- ── Live sensor values ─────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSensorValues"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/surface"
                android:visibility="visible"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="2dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_sensor_acc"
                            android:textSize="15sp"
                            android:textColor="@color/hint_text"/>
                        <TextView
                            android:id="@+id/tvAccValues"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/data_ex"
                            android:textSize="15sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_sensor_gyro"
                            android:textSize="15sp"
                            android:textColor="@color/hint_text"/>
                        <TextView
                            android:id="@+id/tvGyroValues"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/data_ex"
                            android:textSize="15sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                    <com.datn.datacollectv2.view.SensorBarChartView
                        android:id="@+id/sensorBarChart"
                        android:layout_width="match_parent"
                        android:layout_height="28dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Status text -->
            <TextView
                android:id="@+id/tvStatusSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="@color/teal_600"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Bottom buttons ────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp"
        android:paddingTop="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopRecording"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/btn_stop_recording"
            android:textSize="15sp"
            android:textColor="@color/coral_800"
            android:visibility="gone"
            android:layout_marginBottom="6dp"
            app:strokeColor="@color/error"
            app:strokeWidth="1.5dp"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_stop"
            app:iconGravity="start"
            app:iconPadding="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToForm"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/btn_next_form"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:visibility="gone"
            app:backgroundTint="@color/teal_600"
            app:cornerRadius="10dp"/>

    </LinearLayout>

</LinearLayout>